# Database Configuration
# Get your PostgreSQL connection string from your database provider (e.g., Neon, Supabase, Railway)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Optional: Application Settings
# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Training scorer feature flag
# Set to "off" to revert to the legacy hybridScore scorer with no redeploy.
# Default (unset or any other value): new concept-level scorer is active.
# FLEXIBLE_SCORER=off

# Scoring observability (first 2 weeks of rollout only)
# Set to "on" to log {oldScore, newScore, delta} per question to stdout.
# Vercel log drain captures this — remove after confirming score distribution is healthy.
# SCORING_LOG_DELTA=on
