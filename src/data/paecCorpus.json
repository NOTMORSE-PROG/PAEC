        "icaoRef": "ICAO Doc 4444 §4.3.6"
      },
      {
        "incorrect": "to (in number sequences)",
        "correct": "two",
        "explanation": "'To' can be confused with 'two' in number sequences (e.g., 'one to three' should be 'one two three').",
        "pattern": "\\b(one|three|four|five|six|seven|eight|nine|niner|zero)\\s+to\\s+(one|two|three|four|five|six|seven|eight|nine|niner|zero)\\b",
